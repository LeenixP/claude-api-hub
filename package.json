{
  "name": "claude-api-hub",
  "version": "6.2.0",
  "description": "Multi-provider API gateway for Claude Code — route requests to any LLM provider with zero config switching",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "claude-api-hub": "dist/index.js"
  },
  "files": [
    "dist",
    "config",
    "static",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-ui.mjs",
    "build:ui": "node scripts/build-ui.mjs",
    "build:ts": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:ui": "node scripts/build-ui.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "api-gateway",
    "kimi",
    "minimax",
    "glm",
    "zhipu",
    "moonshot",
    "deepseek",
    "kiro",
    "anthropic",
    "openai-compatible",
    "llm",
    "multi-provider",
    "proxy"
  ],
  "author": "LeenixP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeenixP/claude-api-hub.git"
  },
  "homepage": "https://github.com/LeenixP/claude-api-hub#readme",
  "bugs": {
    "url": "https://github.com/LeenixP/claude-api-hub/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.22.0",
    "htm": "^3.1.1",
    "postcss": "^8.5.0",
    "preact": "^10.26.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "claude-api-hub": "^6.1.1"
  }
}
