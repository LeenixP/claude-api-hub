# Claude API Hub — Environment Variables
# Copy this file to .env and fill in your API keys.
# Dashboard password is set in config/providers.json ("password" field).

# ─── API Keys ───
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...
MINIMAX_API_KEY=sk-...
ZHIPUAI_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# ─── Server (optional overrides) ───
# API_HUB_PORT=9800
# API_HUB_HOST=0.0.0.0
