# Claude API Hub — Environment Variables
# Copy this file to .env and fill in your API keys.
# Dashboard password is set in config/providers.json ("password" field).

# =============================================================================
# API KEYS
# =============================================================================
# Add your LLM provider API keys here.
# Use ${VAR_NAME} syntax in providers.json to reference these values.

# Anthropic API Key (official Claude models)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek API Key (DeepSeek models)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Moonshot AI / Kimi API Key
# Get yours at: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-your-kimi-key

# MiniMax API Key
# Get yours at: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=your-minimax-key

# Zhipu AI / GLM API Key
# Get yours at: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your-zhipu-key

# OpenAI API Key (for OpenAI-compatible providers)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key


# =============================================================================
# SERVER CONFIGURATION (Optional Overrides)
# =============================================================================

# Port to listen on (default: 9800)
# API_HUB_PORT=9800

# Host to bind to (default: 0.0.0.0)
# For local-only access, use: 127.0.0.1
# For Docker/remote access, use: 0.0.0.0
# API_HUB_HOST=0.0.0.0


# =============================================================================
# ADMIN AUTHENTICATION
# =============================================================================
# Admin token for protecting management API endpoints
# Set this to protect the dashboard and config APIs
# ADMIN_TOKEN=your-secure-admin-token


# =============================================================================
# KIRO OAUTH (Optional)
# =============================================================================
# Kiro provider uses OAuth instead of API keys.
# Authorization is done through the Web UI dashboard.
# No environment variables needed for Kiro.


# =============================================================================
# CUSTOM PROVIDER KEYS
# =============================================================================
# Add any additional provider keys using this naming convention:
# PROVIDER_NAME_API_KEY=your-key
#
# Example for custom providers:
# OPENROUTER_API_KEY=sk-or-your-key
# ANYSCALE_API_KEY=your-anyscale-key
# MISTRAL_API_KEY=your-mistral-key
